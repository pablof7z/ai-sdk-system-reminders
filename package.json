{
  "name": "ai-sdk-system-reminders",
  "version": "0.1.0",
  "description": "AI SDK middleware for injecting per-request reminders into model calls without rebuilding your base prompt",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "ai-sdk",
    "middleware",
    "system-reminders",
    "prompt"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pablof7z/ai-sdk-system-reminders.git"
  },
  "peerDependencies": {
    "@ai-sdk/provider": ">=2.0.0"
  },
  "devDependencies": {
    "@ai-sdk/provider": "^3.0.8",
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.0"
  }
}
