{
  "name": "ai-sdk-system-reminders",
  "version": "0.2.0",
  "description": "Dynamic prompt injection for multi-step AI agents built on the Vercel AI SDK",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "example:01": "bun examples/01-persistent-reminders.ts",
    "example:02": "bun examples/02-tool-side-effects.ts",
    "example:03": "bun examples/03-heuristic-nudges.ts",
    "example:04": "bun examples/04-deferred-across-runs.ts",
    "example:all": "bun run example:01 && bun run example:02 && bun run example:03 && bun run example:04",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "ai-sdk",
    "middleware",
    "system-reminders",
    "prompt"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pablof7z/ai-sdk-system-reminders.git"
  },
  "peerDependencies": {
    "@ai-sdk/provider": ">=2.0.0"
  },
  "devDependencies": {
    "ai": "^6.0.116",
    "@ai-sdk/provider": "^3.0.8",
    "@types/bun": "^1.2.0",
    "chalk": "^5.6.2",
    "ollama-ai-provider-v2": "^3.4.0",
    "zod": "^4.3.6",
    "typescript": "^5.7.0"
  }
}
