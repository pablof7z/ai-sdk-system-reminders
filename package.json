{
  "name": "ai-sdk-system-reminders",
  "version": "0.2.0",
  "description": "Stateful system reminders runtime and AI SDK middleware for per-request typed prompt injections",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "example:01": "bun examples/01-computed-reminders.ts",
    "example:02": "bun examples/02-current-cycle-reminders.ts",
    "example:03": "bun examples/03-next-cycle-reminders.ts",
    "example:04": "bun examples/04-middleware-injection.ts",
    "example:05": "bun examples/05-xml-utilities.ts",
    "example:all": "bun run example:01 && bun run example:02 && bun run example:03 && bun run example:04 && bun run example:05",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "ai-sdk",
    "middleware",
    "system-reminders",
    "prompt"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pablof7z/ai-sdk-system-reminders.git"
  },
  "peerDependencies": {
    "@ai-sdk/provider": ">=2.0.0"
  },
  "devDependencies": {
    "@ai-sdk/provider": "^3.0.8",
    "@types/bun": "^1.2.0",
    "typescript": "^5.7.0"
  }
}
